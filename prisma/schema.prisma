// 오늘수영 스키마 — 제보(Report) + 수영장 데이터(Pool, 요금은 Pool.fees JSON) + 신선도 감시.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Report {
  id        String       @id @default(cuid())
  /// 프론트 pools.json의 시설 id (예: hanam-misa). 2단계에서 Pool 테이블 FK로 승격
  poolId    String
  /// 제보 사유: 프론트 REASONS와 동일한 한국어 라벨을 그대로 저장
  reason    String
  content   String       @default("")
  /// 익명 기기 식별자 (localStorage UUID) — "내 제보 내역" 조회용
  deviceId  String
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([deviceId, createdAt])
  @@index([status])
}

enum ReportStatus {
  PENDING // 확인 대기
  APPLIED // 정보에 반영됨
  REJECTED // 반영 불가
}

/// Web Push 구독 (아침 요약). 브라우저가 발급한 endpoint가 곧 식별자
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

/// Web Push 구독 (강습 접수 소식). 아침 요약과는 별개 토픽 — 구독을 따로 관리한다
model LessonSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

/// 수영장 시설. 프론트 data/pools.json 의 pool 한 건과 동일한 필드 집합.
/// GET /pools 는 이 테이블을 프론트 계약 shape 로 돌려준다.
/// 전국 확장(2_nationwide): 요금(fees)·자유수영(freeSwim)·강습(lessons)은 시설마다
/// 있을 수도 없을 수도 있어 nullable. dataStatus 로 "기본정보만(listing)" vs "완비(full)" 구분.
model Pool {
  id         String @id
  name       String
  /// 광역(시도) — 전국 필터/검색 기준. 벌크 임포트 시 주소에서 파싱
  sido       String?
  /// 기초(시군구)
  sigungu    String?
  /// 표시용 세부 지역 라벨(예: "미사"). 필수 아님
  region     String?
  operator   String
  phone      String
  address    String
  lat        Float
  lng        Float
  laneInfo   String
  notice     String
  websiteUrl String
  sourceUrl  String
  /// 원본 표기 그대로의 문자열 날짜(예: "2026-06-01"). 날조 방지 위해 문자열 유지
  updatedAt  String
  /// 자유수영 세션 배열 등 원본 JSON. 리스팅 전용 시설은 null
  freeSwim   Json?
  /// 강습 정보 원본 JSON. 리스팅 전용 시설은 null
  lessons    Json?
  /// 요금표 { full:{대상:금액}, half:{...} }. 시설별. 데이터 없으면 null
  fees       Json?
  /// "listing"(기본정보만) | "full"(자유수영·요금까지). 벌크 임포트 기본값 listing
  dataStatus String @default("listing")

  /// 운영 추적용(원본 updatedAt 과 별개). 레코드 생성/갱신 시각
  createdAt   DateTime @default(now())
  dbUpdatedAt DateTime @updatedAt

  @@index([sido, sigungu])
}

/// 신선도 감시용 마지막 스냅샷. 원본 페이지 URL 당 1건.
model CrawlSnapshot {
  id          String   @id @default(cuid())
  url         String   @unique
  contentHash String
  content     String
  fetchedAt   DateTime @updatedAt
}

/// 원본 변경 감지 기록. 자동 반영은 하지 않고 사람 검토를 남긴다.
model FreshnessAlert {
  id         String   @id @default(cuid())
  url        String
  oldHash    String
  newHash    String
  detectedAt DateTime @default(now())
  resolved   Boolean  @default(false)

  @@index([resolved, detectedAt])
}

/// 신선도 알림을 받을 관리자 기기(단일 행). Web Push 구독 정보.
model AdminPushTarget {
  id        String   @id @default("singleton")
  endpoint  String
  p256dh    String
  auth      String
  updatedAt DateTime @updatedAt
}

/// 자유수영 시간표 AI 초안 검수 큐.
/// enrich-swim-schedules 스크립트가 카카오 검색+Gemini 추출로 PENDING 초안을 적재하고,
/// 어드민이 검수·승인해야 Pool.freeSwim 에 반영된다(자동 발행 금지 — 잘못된 시간은 헛걸음을 유발).
model ScheduleDraft {
  id     String @id @default(cuid())
  poolId String
  /// 어드민 목록 표시용 denormalized 시설명
  poolName String
  /// AI 추출 세션 배열(정규 FreeSwimSession[] shape). 승인 시 Pool.freeSwim.sessions 로 반영
  sessions Json
  laneInfo String @default("")
  notice   String @default("")
  /// 근거 스니펫(검수·감사용) + 검색 쿼리
  sourceContext String @default("")
  sourceQuery   String @default("")
  /// AI 자기신뢰도: 'low' | 'medium' | 'high'
  confidence String      @default("low")
  status     DraftStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  reviewedAt DateTime?

  @@index([status, createdAt])
  @@index([poolId])
}

enum DraftStatus {
  PENDING // 검수 대기
  APPROVED // 승인 → Pool 반영됨
  REJECTED // 반려
}
