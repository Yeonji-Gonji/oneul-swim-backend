# docker compose용 (서버의 .env)
POSTGRES_PASSWORD=change-me
API_DOMAIN=api.example.com
CORS_ORIGINS=https://oneul-swim.vercel.app,http://localhost:3000

# 로컬 개발용 (pnpm dev)
DATABASE_URL=postgresql://oneul:change-me@localhost:5432/oneul_swim

# 미니 어드민 인증 토큰 (Authorization: Bearer <token>). 미설정 시 /admin 라우트는 503
ADMIN_TOKEN=

# 어드민 카카오 로그인: 본인 카카오 사용자 id 만 어드민 토큰을 발급받는다.
#   - 조회법: 카카오 로그인 후 GET https://kapi.kakao.com/v2/user/me 의 "id" 값(숫자)
#   - client_id 는 KAKAO_REST_KEY 재사용. 카카오 개발자콘솔에서 "카카오 로그인" 활성화 +
#     Redirect URI 에 <프론트도메인>/admin, http://localhost:3000/admin 등록 필요
ADMIN_KAKAO_ID=
# (선택) 카카오 개발자콘솔에서 client_secret 을 켠 경우에만 설정
KAKAO_CLIENT_SECRET=

# Web Push(VAPID). `npx web-push generate-vapid-keys` 로 발급. 미설정 시 푸시 발송 비활성
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:upfall.juni@gmail.com

# 운영 스크립트용(크론에서 인라인으로 넘겨도 됨. 미설정 시 해당 기능 스킵/종료)
# 백업 성공 핑(healthchecks.io). scripts/backup.sh
HEALTHCHECK_BACKUP_URL=
# DuckDNS 동적 DNS. scripts/duckdns.sh (DUCKDNS_DOMAIN 은 서브도메인 이름만)
DUCKDNS_DOMAIN=
DUCKDNS_TOKEN=
